#!/usr/bin/make -f

%:
	dh $@ --with python3 --buildsystem=pybuild --with python3

override_dh_auto_test:
	# Skip tests during package build
	@echo "Skipping tests during package build"

override_dh_shlibdeps:
	# Skip automatic dependency calculation
	@echo "Skipping shlibdeps"

override_dh_python3:
	# Skip automatic Python dependency calculation
	dh_python3 --no-guessing-deps

override_dh_auto_install:
	dh_auto_install
	# Copy wheel .dist-info to replace .egg-info if it exists
	@echo "=== Looking for wheel .dist-info ==="
	@ls -la dist/ || echo "No dist directory found"
	@if [ -d "dist/netpulse-1.1.0.dist-info" ]; then \
		echo "Found wheel .dist-info, copying to replace .egg-info"; \
		rm -rf debian/netpulse/usr/lib/python3*/dist-packages/netpulse-1.1.0.egg-info; \
		cp -r dist/netpulse-1.1.0.dist-info debian/netpulse/usr/lib/python3*/dist-packages/; \
	else \
		echo "No wheel .dist-info found, keeping .egg-info"; \
	fi
	# Install systemd files
	install -d debian/netpulse/lib/systemd/system
	install -m 644 systemd/*.service debian/netpulse/lib/systemd/system/
	install -m 644 systemd/*.timer debian/netpulse/lib/systemd/system/

override_dh_fixperms:
	dh_fixperms
	chmod +x debian/postinst
	chmod +x debian/prerm
	chmod +x debian/rules
