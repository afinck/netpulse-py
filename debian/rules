#!/usr/bin/make -f

%:
	dh $@ --with python3 --buildsystem=pybuild --with python3

override_dh_auto_test:
	# Skip tests during package build
	@echo "Skipping tests during package build"

override_dh_shlibdeps:
	# Skip automatic dependency calculation
	@echo "Skipping shlibdeps"

override_dh_python3:
	# Skip automatic Python dependency calculation
	dh_python3 --no-guessing-deps

override_dh_auto_install:
	dh_auto_install
	# Install templates and static files to the correct Python 3.11 path
	mkdir -p debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/templates
	cp -r templates/*.html debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/templates/ || true
	cp templates/__init__.py debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/templates/ || true
	if [ -d "static/css" ]; then \
		mkdir -p debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/static/css; \
		cp -r static/css/*.css debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/static/css/ || true; \
	fi
	if [ -d "static/js" ]; then \
		mkdir -p debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/static/js; \
		cp -r static/js/*.js debian/netpulse/usr/lib/python3.11/dist-packages/netpulse/static/js/ || true; \
	fi
	# Install systemd files
	install -d debian/lib/systemd/system
	install -m 644 systemd/*.service debian/lib/systemd/system/
	install -m 644 systemd/*.timer debian/lib/systemd/system/

override_dh_fixperms:
	dh_fixperms
	chmod +x debian/DEBIAN/postinst
	chmod +x debian/DEBIAN/prerm
	chmod +x debian/rules
